<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <com.mamad.portfolio360.SplashChartView
        android:id="@+id/splashChart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/glowCircle"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/glow_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.56"/>

    <!-- نشان‌های دارایی شناور -->

    <ImageView
        android:id="@+id/badgeBtc"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:padding="9dp"
        android:background="@drawable/badge_glass_bg"
        android:src="@drawable/ic_bitcoin"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:contentDescription="BTC"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.14"
        app:layout_constraintVertical_bias="0.20"/>

    <ImageView
        android:id="@+id/badgeGoogl"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="8dp"
        android:background="@drawable/badge_glass_bg"
        android:src="@drawable/ic_google"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:contentDescription="GOOGL"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintVertical_bias="0.10"/>

    <ImageView
        android:id="@+id/badgeEth"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:padding="9dp"
        android:background="@drawable/badge_glass_bg"
        android:src="@drawable/ic_ethereum"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:contentDescription="ETH"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.84"
        app:layout_constraintVertical_bias="0.17"/>

    <ImageView
        android:id="@+id/badgeNvda"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="8dp"
        android:background="@drawable/badge_glass_bg"
        android:src="@drawable/ic_nvidia"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:contentDescription="NVDA"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.08"
        app:layout_constraintVertical_bias="0.42"/>

    <ImageView
        android:id="@+id/badgeMeta"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="8dp"
        android:background="@drawable/badge_glass_bg"
        android:src="@drawable/ic_meta"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:contentDescription="META"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.90"
        app:layout_constraintVertical_bias="0.40"/>

    <!-- برندینگ مرکزی -->

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Portfolio360"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:alpha="0"
        android:translationY="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.60"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تحلیل هوشمند آپشن و بهینه‌سازی پرتفوی"
        android:textColor="#8892B0"
        android:textSize="14sp"
        android:alpha="0"
        android:translationY="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        android:layout_marginTop="10dp"/>

    <View
        android:id="@+id/dividerLine"
        android:layout_width="240dp"
        android:layout_height="1dp"
        android:background="#1E3A5F"
        android:alpha="0"
        android:scaleX="0"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <LinearLayout
        android:id="@+id/tagRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0"
        android:translationY="16dp"
        app:layout_constraintTop_toBottomOf="@id/dividerLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تحلیل آپشن"
            android:textColor="#00D4FF"
            android:textSize="11sp"
            android:background="@drawable/tag_bg_blue"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="بهینه‌سازی پرتفوی"
            android:textColor="#9B7FFF"
            android:textSize="11sp"
            android:background="@drawable/tag_bg_purple"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="110dp"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:indeterminateTint="#38BDF8"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/tagRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="46dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
