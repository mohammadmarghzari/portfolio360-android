<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0E1A">

    <View
        android:id="@+id/glowCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/glow_circle"
        android:alpha="0"/>

    <ImageView
        android:id="@+id/ethIcon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_ethereum"
        android:alpha="0"
        android:scaleX="0.4"
        android:scaleY="0.4"
        android:layout_marginTop="-154dp"
        android:contentDescription="ETH"/>

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="آپشن‌یار"
        android:textColor="#FFFFFF"
        android:textSize="38sp"
        android:textStyle="bold"
        android:alpha="0"
        android:translationY="30dp"
        android:layout_marginTop="28dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تحلیل هوشمند قراردادهای آپشن"
        android:textColor="#8892B0"
        android:textSize="14sp"
        android:alpha="0"
        android:translationY="20dp"
        android:layout_marginTop="10dp"/>

    <View
        android:id="@+id/dividerLine"
        android:layout_width="260dp"
        android:layout_height="1dp"
        android:background="#1E3A5F"
        android:alpha="0"
        android:scaleX="0"
        android:layout_marginTop="22dp"/>

    <LinearLayout
        android:id="@+id/tagRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0"
        android:translationY="16dp"
        android:layout_marginTop="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Covered Call"
            android:textColor="#00D4FF"
            android:textSize="11sp"
            android:background="@drawable/tag_bg_blue"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protective Put"
            android:textColor="#9B7FFF"
            android:textSize="11sp"
            android:background="@drawable/tag_bg_purple"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="100dp"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:indeterminateTint="#00D4FF"
        android:alpha="0"
        android:layout_marginTop="60dp"/>

</LinearLayout>
