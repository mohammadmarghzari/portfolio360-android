<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blueprint_bg">

    <!-- انتخاب دارایی پایه -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp">

        <LinearLayout
            android:id="@+id/currency_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- نوار وضعیت / قیمت لحظه‌ای -->
    <TextView
        android:id="@+id/chain_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:gravity="center"
        android:textColor="@color/blueprint_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:text="@string/chain_loading" />

    <!-- حباب/پرمیوم مشتقه دارایی پایه -->
    <TextView
        android:id="@+id/chain_basis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="8dp"
        android:gravity="center"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- راهنمای حالت انتخاب -->
    <TextView
        android:id="@+id/chain_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:gravity="center"
        android:textColor="@color/blueprint_accent"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- انتخاب تاریخ سررسید -->
    <HorizontalScrollView
        android:id="@+id/expiry_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/expiry_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- سربرگ ستون‌ها: کال (چپ) | استرایک (وسط) | پوت (راست) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/blueprint_surface"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layoutDirection="ltr">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chain_calls"
            android:textColor="@color/chain_call"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.55"
            android:gravity="center"
            android:text="@string/chain_strike"
            android:textColor="@color/blueprint_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chain_puts"
            android:textColor="@color/chain_put"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- زیرسربرگ گریک‌ها -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/blueprint_surface"
        android:paddingBottom="6dp"
        android:layoutDirection="ltr">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chain_greek_header"
            android:textColor="@color/blueprint_text"
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.55"
            android:gravity="center"
            android:text=""
            android:textSize="10sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/chain_greek_header"
            android:textColor="@color/blueprint_text"
            android:textSize="10sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/blueprint_grid_line" />

    <!-- ردیف‌های استرایک -->
    <ScrollView
        android:id="@+id/chain_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/chain_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>
