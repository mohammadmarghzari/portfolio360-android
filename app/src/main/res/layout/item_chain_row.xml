<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:layoutDirection="ltr">

    <!-- سمت چپ: کال -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/call_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/chain_call"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_greeks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/blueprint_text"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- وسط: قیمت اعمال -->
    <TextView
        android:id="@+id/strike_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.55"
        android:gravity="center"
        android:textColor="@color/blueprint_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- سمت راست: پوت -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/put_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/chain_put"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/put_greeks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/blueprint_text"
            android:textSize="9sp" />
    </LinearLayout>

</LinearLayout>
