<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blueprint_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pp_input_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- قیمت خرید (بهای تمام شده) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_cost_basis">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_cost_basis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="1700" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- قیمت اعمال پوت (کف محافظت) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_put_strike">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_strike"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="1600" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- پرمیوم پرداختی -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_premium_paid">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_premium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="45" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- روز تا سررسید -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_days_to_expiry">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="30" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/btn_calculate"
            app:backgroundTint="@color/blueprint_primary" />

        <!-- نتایج -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/blueprint_surface"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/results_title"
                    android:textColor="@color/blueprint_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/result_breakeven"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_max_loss"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_protection_level"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_insurance_cost"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_annualized_cost"
                    style="@style/ResultRow" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
