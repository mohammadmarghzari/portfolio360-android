<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blueprint_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cc_input_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- قیمت خرید (بهای تمام شده) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_cost_basis">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_cost_basis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="1700" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- قیمت لحظه‌ای فعلی -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_spot_price">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_spot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="1770" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- قیمت اعمال کال فروخته‌شده -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_strike">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_strike"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="1900" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- پرمیوم دریافتی -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_premium">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_premium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="65" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- روز تا سررسید -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_days_to_expiry">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="30" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- بازده موردانتظار سالانه -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_expected_return">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_expected_return"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="25" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- نرخ بدون ریسک سالانه -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/label_risk_free_rate">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_risk_free_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="30" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/btn_calculate"
            app:backgroundTint="@color/blueprint_primary" />

        <!-- نتایج -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/blueprint_surface"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/results_title"
                    android:textColor="@color/blueprint_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/result_breakeven"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_max_profit"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_static_return"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_if_called_return"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_annualized_return"
                    style="@style/ResultRow" />

                <TextView
                    android:id="@+id/result_downside_protection"
                    style="@style/ResultRow" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- نمودار سود/زیان -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/chart_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/payoff_chart_title"
                    android:textColor="@color/chart_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/cc_payoff_chart"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- نظر و استدلال سرمایه‌گذاری -->
        <TextView
            android:id="@+id/result_verdict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="14dp"
            android:background="@drawable/chip_selected_background"
            android:textColor="@color/blueprint_text"
            android:textSize="13sp"
            android:lineSpacingExtra="5dp" />

    </LinearLayout>
</ScrollView>
