<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blueprint_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:text="@string/sub_subtitle"
            android:textColor="@color/blueprint_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/sub_status_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/chip_selected_background"
            android:textColor="@color/blueprint_accent"
            android:textSize="12sp" />

        <!-- پلن‌ها -->
        <LinearLayout
            android:id="@+id/sub_plans_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- اطلاعات پرداخت -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="10dp"
            android:text="@string/sub_payment_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/chart_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_card_number_label"
                    android:textColor="@color/chart_baseline"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sub_card_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/sub_card_number_value"
                    android:textColor="@color/premium_gold"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/sub_copy_card"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    app:cornerRadius="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/sub_steps"
                    android:textColor="@color/chart_text"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_receipt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/sub_send_receipt_button"
                    app:backgroundTint="@color/premium_gold"
                    android:textColor="#1A1200" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/sub_note"
                    android:textColor="@color/chart_baseline"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
