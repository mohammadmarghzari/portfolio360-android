<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blueprint_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:text="@string/sub_subtitle"
            android:textColor="@color/blueprint_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/sub_status_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/chip_selected_background"
            android:textColor="@color/blueprint_accent"
            android:textSize="12sp" />

        <!-- پلن‌ها -->
        <LinearLayout
            android:id="@+id/sub_plans_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- اطلاعات پرداخت -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="10dp"
            android:text="@string/sub_payment_title"
            android:textColor="@color/blueprint_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/chart_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- کارت بانکی -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:background="@drawable/bg_bank_card"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:text="@string/sub_bank_name"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="38dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="3dp"
                        android:background="@drawable/bg_card_chip" />

                    <TextView
                        android:id="@+id/sub_card_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:textDirection="ltr"
                        android:text="@string/sub_card_number_value"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:text="@string/sub_card_holder_name"
                        android:textColor="#D8DEEC"
                        android:textSize="13sp"
                        android:letterSpacing="0.03" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:text="@string/sub_card_network"
                        android:textColor="@color/premium_gold"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/sub_copy_card"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    app:cornerRadius="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:background="#1E293B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/sub_your_email_label"
                    android:textColor="@color/chart_baseline"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sub_user_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textDirection="ltr"
                    android:gravity="start"
                    android:textColor="@color/chart_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textIsSelectable="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/sub_copy_email"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    app:cornerRadius="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/sub_steps"
                    android:textColor="@color/chart_text"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_receipt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/sub_send_receipt_button"
                    app:backgroundTint="@color/premium_gold"
                    android:textColor="#1A1200" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/sub_note"
                    android:textColor="@color/chart_baseline"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
