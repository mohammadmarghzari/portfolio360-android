<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <View
        android:id="@+id/weight_row_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/dot_shape" />

    <TextView
        android:id="@+id/weight_row_symbol"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:textColor="@color/chart_text"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/weight_row_percent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:textColor="@color/chart_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/weight_row_dollar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/blueprint_accent"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
